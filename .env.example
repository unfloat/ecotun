# Postgres (Vercel Postgres / Neon). For Vercel, map these to POSTGRES_PRISMA_URL / POSTGRES_URL_NON_POOLING.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/ecotun?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/ecotun?sslmode=require"

# Auth.js — Required for admin area protection (Task 10)
# AUTH_SECRET: run `npx auth secret` or generate with:
#   node -e "const c=require('crypto');console.log(c.randomBytes(32).toString('base64url'))"
AUTH_SECRET=""
# ADMIN_EMAIL: the single admin account email
ADMIN_EMAIL="admin@ecotun.tn"
# ADMIN_PASSWORD_HASH: bcrypt hash (cost 12) of the admin password
#   generate with: npx tsx scripts/hash-password.ts <your-password>
ADMIN_PASSWORD_HASH=""
